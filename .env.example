# Code Review Assistant - 通知渠道配置
# 复制此文件为 .env，填入你的凭证即可自动启用通知
# cp .env.example .env

# ============================================
# 国内常用 (推荐)
# ============================================

# 飞书机器人 Webhook
# 获取方式: 群设置 -> 添加机器人 -> 自定义机器人 -> 复制 Webhook URL
FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx

# 钉钉机器人 Webhook + 加签密钥 (可选)
# 获取方式: 群设置 -> 智能群助手 -> 添加机器人 -> 自定义
DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=xxxxxxxx
# DINGTALK_SECRET=SECxxxxxxxx

# 企业微信机器人 Webhook
# 获取方式: 群设置 -> 添加群机器人 -> 复制 Webhook 地址
WECOM_WEBHOOK=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxxxxxxx

# ============================================
# 国际常用
# ============================================

# Slack Webhook
# 获取方式: Slack App -> Incoming Webhooks -> Add New Webhook
SLACK_WEBHOOK=https://hooks.slack.com/services/xxx/yyy/zzz

# Telegram Bot
# 获取方式: @BotFather -> /newbot -> 获取 Token
# Chat ID: 向 bot 发消息 -> https://api.telegram.org/bot<token>/getUpdates
TELEGRAM_BOT_TOKEN=bot123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TELEGRAM_CHAT_ID=-123456789

# LINE Notify
# 获取方式: https://notify-bot.line.me/my/ -> 生成 Token
LINE_NOTIFY_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# WhatsApp (Twilio)
# 获取方式: twilio.com/console -> Account SID & Auth Token
# WhatsApp 号码需通过 Twilio 验证
TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WHATSAPP_FROM=+1234567890

# ============================================
# 邮件
# ============================================

# SMTP 配置 (以 Gmail 为例)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# ============================================
# 配置完成后，无需任何参数即可启用通知:
#   ./scheduled-review.sh --now
#
# 或手动指定:
#   ./scheduled-review.sh --now --notify feishu
#   ./scheduled-review.sh --now --notify email --to team@example.com
# ============================================
